        function renderMarketSnapshot(payload) {
            const grid = document.getElementById('macro-indicators-grid');
            const meta = document.getElementById('macro-indicators-meta');
            if (!grid || !meta) return;

            const indicators = Array.isArray(payload?.indicators) ? payload.indicators : [];
            if (!indicators.length) {
                grid.innerHTML = '<div class="col-span-full text-xs text-slate-400 bg-slate-900/60 border border-slate-700 rounded-lg p-3">لا توجد قراءات لحظية متاحة حالياً.</div>';
                meta.textContent = payload?.error ? `تعذر تحميل المؤشرات: ${payload.error}` : 'تعذر تحميل المؤشرات حالياً.';
                return;
            }

            grid.innerHTML = indicators.map((item) => {
                const isUp = Number(item.change_percent || 0) >= 0;
                const price = item.price === null || item.price === undefined ? '--' : Number(item.price).toLocaleString('en-US', { maximumFractionDigits: 3 });
                const chg = item.change_percent === null || item.change_percent === undefined ? '--' : `${isUp ? '+' : ''}${Number(item.change_percent).toFixed(2)}%`;
                return `
                    <div class="bg-slate-800 p-3 rounded-lg border border-slate-700">
                        <p class="text-[11px] text-slate-400 mb-1">${escapeHtml(item.label || '')}</p>
                        <p class="text-lg font-bold ${isUp ? 'text-emerald-400' : 'text-red-400'}">${escapeHtml(price)}</p>
                        <p class="text-[10px] ${isUp ? 'text-emerald-500' : 'text-red-500'}">${escapeHtml(chg)}</p>
                    </div>
                `;
            }).join('');

            meta.textContent = `آخر تحديث للمؤشرات: ${formatDateTime(payload.updated_at)} | المصدر: Yahoo Finance (بيانات لحظية قد تكون متأخرة دقائق)`;
        }

        async function loadMarketSnapshot() {
            try {
                const response = await fetchApi('/api/market-snapshot', { method: 'GET', headers: { 'Accept': 'application/json' } });
                const payload = await response.json();
                renderMarketSnapshot(payload);
            } catch (error) {
                renderMarketSnapshot({ ok: false, error: error.message, indicators: [] });
            }
        }

        async function loadNews(force = false) {
            try {
                const response = await fetchApi(`/api/news${force ? '?force=1' : ''}`, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' }
                });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const payload = await response.json();
                if (!payload?.ok) throw new Error(payload?.error || 'تعذر جلب الأخبار');

                APP_STATE.latestPayload = payload;
                renderMergedTabs(payload.news, payload);
                renderTicker(payload.news);
                loadMarketSnapshot();
            } catch (error) {
                const track = document.getElementById('news-ticker-track');
                if (track) {
                    track.innerHTML = `<span class="ticker-chip"><i class="fas fa-triangle-exclamation text-red-400"></i> تعذر جلب الأخبار: ${escapeHtml(error.message)} | تحقق من تشغيل server.js</span>`;
                }
            }
        }

