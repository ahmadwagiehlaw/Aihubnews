        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function escapeAttr(value) {
            return escapeHtml(value).replace(/`/g, '&#96;');
        }

        function formatDateTime(value) {
            if (!value) return '--';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            return date.toLocaleString('ar-EG', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function normalizeApiBase(base) {
            const raw = String(base || '').trim();
            if (!raw) return '';
            let out = raw;
            if (!/^https?:\/\//i.test(out)) {
                out = `${window.location.protocol}//${out}`;
            }
            out = out.replace(/\/+$/g, '');
            return out;
        }

        function setApiStatus(text, kind = 'muted') {
            const el = document.getElementById('api-base-status');
            if (!el) return;
            const cls = kind === 'ok'
                ? 'text-xs text-emerald-300 mt-2'
                : kind === 'error'
                    ? 'text-xs text-red-300 mt-2'
                    : 'text-xs text-slate-400 mt-2';
            el.className = cls;
            el.textContent = text;
        }

        function setApiBase(base, persist = true) {
            const normalized = normalizeApiBase(base);
            APP_STATE.apiBase = normalized;
            APP_STATE.apiReady = false;
            if (!persist) return;

            if (!normalized || normalized === window.location.origin) {
                localStorage.removeItem('aihub_api_base');
            } else {
                localStorage.setItem('aihub_api_base', normalized);
            }
        }

        function buildAutoApiCandidates() {
            const protocol = window.location.protocol || 'http:';
            const host = window.location.hostname || '127.0.0.1';
            const activePort = String(window.location.port || '').trim();
            const ports = [...new Set([activePort, ...API_PORT_CANDIDATES].filter(Boolean))];
            const hosts = [...new Set(
                ['127.0.0.1', 'localhost'].includes(host)
                    ? [host, host === '127.0.0.1' ? 'localhost' : '127.0.0.1']
                    : [host]
            )];

            const out = [''];
            hosts.forEach((h) => {
                ports.forEach((p) => {
                    out.push(`${protocol}//${h}:${p}`);
                });
            });
            return [...new Set(out.map((base) => normalizeApiBase(base) || ''))];
        }

        function cleanupBlockedApiBases() {
            const blocked = APP_STATE.apiBlockedBases || {};
            const now = Date.now();
            Object.keys(blocked).forEach((base) => {
                const ts = Number(blocked[base]) || 0;
                if (!ts || (now - ts) > API_BLOCK_TTL_MS) {
                    delete blocked[base];
                }
            });
        }

        function buildApiUrl(path, base = '') {
            const safePath = String(path || '').startsWith('/') ? String(path || '') : `/${String(path || '')}`;
            if (!base) return safePath;
            return `${base}${safePath}`;
        }

        function getOrderedApiBases() {
            cleanupBlockedApiBases();
            const known = buildAutoApiCandidates();
            if (APP_STATE.apiBase && !known.includes(APP_STATE.apiBase)) known.unshift(APP_STATE.apiBase);
            const blocked = APP_STATE.apiBlockedBases || {};
            const filtered = known.filter((base) => !blocked[base]);
            if (APP_STATE.apiBase && !blocked[APP_STATE.apiBase]) {
                return [APP_STATE.apiBase, ...filtered.filter((x) => x !== APP_STATE.apiBase && !blocked[x])];
            }
            if (APP_STATE.apiBase === '' && !blocked['']) {
                return ['', ...filtered.filter((x) => x !== '' && !blocked[x])];
            }
            return filtered;
        }

        async function fetchWithTimeout(url, options = {}, timeoutMs = API_REQUEST_TIMEOUT_MS) {
            const controller = new AbortController();
            const timer = setTimeout(() => controller.abort(), Math.max(700, Number(timeoutMs) || API_REQUEST_TIMEOUT_MS));
            try {
                return await fetch(url, { ...options, signal: controller.signal });
            } finally {
                clearTimeout(timer);
            }
        }

        async function discoverApiBase() {
            if (APP_STATE.discoveringApi) return APP_STATE.apiReady;
            APP_STATE.discoveringApi = true;
            try {
                const bases = getOrderedApiBases();
                for (const base of bases) {
                    const healthUrl = buildApiUrl('/api/health', base);
                    try {
                        const response = await fetchWithTimeout(healthUrl, { method: 'GET', headers: { Accept: 'application/json' } }, API_REQUEST_TIMEOUT_MS);
                        if (!response.ok) {
                            APP_STATE.apiBlockedBases[base] = Date.now();
                            continue;
                        }
                        const payload = await response.json().catch(() => null);
                        if (!payload || payload.ok !== true) continue;
                        if (payload.api_signature !== REQUIRED_API_SIGNATURE) continue;
                        setApiBase(base, true);
                        APP_STATE.apiReady = true;
                        setApiStatus(`تم الاتصال بخادم الأخبار: ${base || 'نفس رابط الصفحة'}`, 'ok');
                        const input = document.getElementById('api-base-input');
                        if (input) input.value = APP_STATE.apiBase || '';
                        return true;
                    } catch (_) {
                        APP_STATE.apiBlockedBases[base] = Date.now();
                    }
                }
                APP_STATE.apiReady = false;
                APP_STATE.lastApiFailureAt = Date.now();
                setApiStatus('تعذر اكتشاف خادم API. شغّل server.js ثم أدخل الرابط يدويًا.', 'error');
                return false;
            } finally {
                APP_STATE.discoveringApi = false;
            }
        }

        async function fetchApi(path, options = {}) {
            if (!APP_STATE.apiReady) {
                if (APP_STATE.lastApiFailureAt && (Date.now() - APP_STATE.lastApiFailureAt < API_RETRY_COOLDOWN_MS)) {
                    throw new Error('API unavailable (cooldown)');
                }
                await discoverApiBase();
                if (!APP_STATE.apiReady && APP_STATE.lastApiFailureAt && (Date.now() - APP_STATE.lastApiFailureAt < API_RETRY_COOLDOWN_MS)) {
                    throw new Error('API unavailable (cooldown)');
                }
            }
            const bases = getOrderedApiBases();
            if (!bases.length) {
                APP_STATE.apiReady = false;
                APP_STATE.lastApiFailureAt = Date.now();
                throw new Error('No API base candidates available');
            }
            let lastError = null;

            for (const base of bases) {
                const url = buildApiUrl(path, base);
                try {
                    const response = await fetchWithTimeout(url, options, API_REQUEST_TIMEOUT_MS);
                    if (response.ok || [400, 401, 403].includes(response.status)) {
                        setApiBase(base, true);
                        APP_STATE.apiReady = true;
                        APP_STATE.lastApiFailureAt = 0;
                        return response;
                    }
                    if ([404, 405, 502, 503, 504].includes(response.status)) {
                        APP_STATE.apiBlockedBases[base] = Date.now();
                        lastError = new Error(`HTTP ${response.status}`);
                        continue;
                    }
                    setApiBase(base, true);
                    APP_STATE.apiReady = true;
                    return response;
                } catch (error) {
                    APP_STATE.apiBlockedBases[base] = Date.now();
                    lastError = error;
                }
            }
            APP_STATE.apiReady = false;
            APP_STATE.lastApiFailureAt = Date.now();
            setApiStatus('فشل الاتصال بـ API. تأكد أن server.js يعمل ثم أعد المحاولة.', 'error');
            throw (lastError || new Error('تعذر الوصول إلى واجهة الـ API'));
        }

        function isStandaloneMode() {
            const mq = window.matchMedia && window.matchMedia('(display-mode: standalone)').matches;
            return Boolean(mq || window.navigator.standalone === true);
        }

        function isIOSDevice() {
            const ua = String(window.navigator.userAgent || '').toLowerCase();
            return /iphone|ipad|ipod/.test(ua);
        }

        function shouldShowInstallBanner() {
            if (isStandaloneMode()) return false;
            if (localStorage.getItem(INSTALL_BANNER_DISMISS_KEY) === '1') return false;
            return true;
        }

        function showInstallBanner(mode = 'generic') {
            if (!shouldShowInstallBanner()) return;
            const banner = document.getElementById('install-banner');
            const overlay = document.getElementById('install-overlay');
            const text = document.getElementById('install-banner-text');
            const installBtn = document.getElementById('install-now-btn');
            if (!banner || !text || !installBtn) return;

            if (mode === 'ios') {
                text.textContent = 'على iPhone: اضغط زر المشاركة في Safari ثم اختر "Add to Home Screen".';
                installBtn.textContent = 'فهمت الخطوات';
            } else {
                text.textContent = 'يمكن تثبيت التطبيق للوصول السريع مثل التطبيقات الأصلية.';
                installBtn.textContent = 'تثبيت الآن';
            }

            if (overlay) overlay.classList.remove('hidden');
            banner.classList.remove('hidden');
            APP_STATE.installBannerShown = true;
        }

        function hideInstallBanner() {
            const banner = document.getElementById('install-banner');
            const overlay = document.getElementById('install-overlay');
            if (banner) banner.classList.add('hidden');
            if (overlay) overlay.classList.add('hidden');
            APP_STATE.installBannerShown = false;
        }

        function initInstallExperience() {
            const installBtn = document.getElementById('install-now-btn');
            const laterBtn = document.getElementById('install-later-btn');
            const neverBtn = document.getElementById('install-never-btn');
            const closeBtn = document.getElementById('install-banner-close');
            const overlay = document.getElementById('install-overlay');

            if (installBtn) {
                installBtn.addEventListener('click', async () => {
                    if (APP_STATE.deferredInstallPrompt) {
                        APP_STATE.deferredInstallPrompt.prompt();
                        try {
                            await APP_STATE.deferredInstallPrompt.userChoice;
                        } catch (_) {}
                        APP_STATE.deferredInstallPrompt = null;
                        hideInstallBanner();
                        return;
                    }
                    hideInstallBanner();
                });
            }
            if (laterBtn) laterBtn.addEventListener('click', hideInstallBanner);
            if (closeBtn) closeBtn.addEventListener('click', hideInstallBanner);
            if (overlay) overlay.addEventListener('click', hideInstallBanner);
            if (neverBtn) {
                neverBtn.addEventListener('click', () => {
                    localStorage.setItem(INSTALL_BANNER_DISMISS_KEY, '1');
                    hideInstallBanner();
                });
            }

            window.addEventListener('beforeinstallprompt', (event) => {
                event.preventDefault();
                APP_STATE.deferredInstallPrompt = event;
                showInstallBanner('android');
            });

            if (shouldShowInstallBanner()) {
                if (isIOSDevice()) {
                    setTimeout(() => showInstallBanner('ios'), 1400);
                } else {
                    setTimeout(() => showInstallBanner('generic'), 2000);
                }
            }
        }

        async function registerServiceWorker() {
            const canRegister = 'serviceWorker' in navigator;
            const secureContext = window.location.protocol === 'https:' || ['localhost', '127.0.0.1'].includes(window.location.hostname);
            if (!canRegister || !secureContext) return;
            try {
                await navigator.serviceWorker.register('./sw.js');
            } catch (_) {
                // Keep silent to avoid disturbing users.
            }
        }

        function normalizeVideoUrl(url) {
            const raw = String(url || '').trim();
            if (!raw) return '';
            try {
                const parsed = new URL(raw, window.location.href);
                if (!/^https?:$/i.test(parsed.protocol)) return '';
                return parsed.toString();
            } catch (_) {
                return '';
            }
        }

        function youtubeEmbedUrl(url) {
            const videoUrl = normalizeVideoUrl(url);
            if (!videoUrl) return '';
            try {
                const u = new URL(videoUrl);
                const host = u.hostname.toLowerCase();
                if (host === 'youtu.be') {
                    const id = u.pathname.replace(/\//g, '').trim();
                    return id ? `https://www.youtube.com/embed/${encodeURIComponent(id)}` : '';
                }
                if (host.includes('youtube.com')) {
                    const id = u.searchParams.get('v');
                    if (id) return `https://www.youtube.com/embed/${encodeURIComponent(id)}`;
                    const parts = u.pathname.split('/').filter(Boolean);
                    if (parts[0] === 'shorts' && parts[1]) {
                        return `https://www.youtube.com/embed/${encodeURIComponent(parts[1])}`;
                    }
                }
            } catch (_) {
                return '';
            }
            return '';
        }

