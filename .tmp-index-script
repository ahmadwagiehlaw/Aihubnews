        async function refreshAdminAiHubList() {
            try {
                const payload = await apiJson('/api/admin/news', { method: 'GET' }, true);
                renderAdminAiHubList(payload.items || []);
            } catch (error) {
                renderAdminAiHubList([]);
                setText('admin-home-status', `تعذر تحميل عناصر الرئيسية: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        async function addAiHubHomeItem() {
            const section = document.getElementById('admin-home-section')?.value || 'announcements';
            const title = String(document.getElementById('admin-home-title')?.value || '').trim();
            const summary = String(document.getElementById('admin-home-summary')?.value || '').trim();
            const source = String(document.getElementById('admin-home-source')?.value || '').trim() || 'AI HUB';
            let sourceUrl = String(document.getElementById('admin-home-source-url')?.value || '').trim();
            let imageUrl = String(document.getElementById('admin-home-image-url')?.value || '').trim();
            const videoUrl = String(document.getElementById('admin-home-video-url')?.value || '').trim();
            const pdfUrl = String(document.getElementById('admin-home-pdf-url')?.value || '').trim();
            const ctaUrl = String(document.getElementById('admin-home-cta-url')?.value || '').trim();
            const ctaLabel = String(document.getElementById('admin-home-cta-label')?.value || '').trim();
            const isFeatured = Boolean(document.getElementById('admin-home-featured')?.checked);
            const imageFile = document.getElementById('admin-home-image-file')?.files?.[0];

            if (!sourceUrl) {
                sourceUrl = ctaUrl || videoUrl || pdfUrl;
            }

            if (!imageUrl && imageFile) {
                imageUrl = await fileToDataUrl(imageFile);
            }

            setText('admin-home-status', 'جارٍ إضافة عنصر الرئيسية...', 'text-xs text-slate-300 mt-3');
            try {
                await apiJson('/api/admin/news', {
                    method: 'POST',
                    body: JSON.stringify({
                        category: 'aihub',
                        scope: 'local',
                        aihub_section: section,
                        title,
                        summary,
                        source,
                        source_url: sourceUrl,
                        image_url: imageUrl,
                        video_url: videoUrl,
                        pdf_url: pdfUrl,
                        cta_url: ctaUrl,
                        cta_label: ctaLabel,
                        is_featured: isFeatured,
                        published_at: new Date().toISOString(),
                        auto_extract: (!title || !summary || !source)
                    })
                }, true);

                ['admin-home-title', 'admin-home-summary', 'admin-home-source', 'admin-home-source-url', 'admin-home-image-url', 'admin-home-video-url', 'admin-home-pdf-url', 'admin-home-cta-url', 'admin-home-cta-label'].forEach((id) => {
                    const el = document.getElementById(id);
                    if (el) el.value = '';
                });
                const homeFile = document.getElementById('admin-home-image-file');
                if (homeFile) homeFile.value = '';
                const homeFeatured = document.getElementById('admin-home-featured');
                if (homeFeatured) homeFeatured.checked = false;

                setText('admin-home-status', 'تمت إضافة العنصر بنجاح في الرئيسية.', 'text-xs text-emerald-300 mt-3');
                await Promise.all([loadNews(false), refreshAdminAiHubList()]);
            } catch (error) {
                setText('admin-home-status', `فشل إضافة عنصر الرئيسية: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        async function refreshAdminAIStatus() {
            try {
                const payload = await apiJson('/api/admin/auto-status', { method: 'GET' }, true);
                const nextRun = payload.next_run_at ? formatDateTime(payload.next_run_at) : '--';
                const lastRun = payload.updated_at ? formatDateTime(payload.updated_at) : '--';
                const err = payload.error ? ` | آخر خطأ: ${payload.error}` : '';
                setText('admin-ai-status', `آخر تحديث: ${lastRun} | القادم: ${nextRun} | المصدر: ${payload.source || '--'}${err}`, 'text-xs text-slate-300');
            } catch (error) {
                setText('admin-ai-status', `تعذر جلب حالة التحديث: ${error.message}`, 'text-xs text-red-300');
            }
        }

        async function adminForceAIRefresh() {
            setText('admin-ai-status', 'جارٍ تنفيذ تحديث AI...', 'text-xs text-cyan-300');
            try {
                const payload = await apiJson('/api/admin/refresh-ai', { method: 'POST' }, true);
                await loadNews(false);
                await refreshAdminAIStatus();
                setText('admin-ai-status', `تم التحديث بنجاح. المصدر: ${payload.source || '--'} | وقت التنفيذ: ${formatDateTime(payload.updated_at)}`, 'text-xs text-emerald-300');
            } catch (error) {
                setText('admin-ai-status', `فشل التحديث الفوري: ${error.message}`, 'text-xs text-red-300');
            }
        }

        async function adminRefreshSources() {
            const category = String(document.getElementById('admin-refresh-category')?.value || 'all');
            setText('admin-refresh-status', 'جارٍ تحديث المصادر الآن...', 'text-xs text-cyan-300 mt-2');
            try {
                const payload = await apiJson('/api/admin/refresh-sources', {
                    method: 'POST',
                    body: JSON.stringify({ category })
                }, true);
                setText('admin-refresh-status', `تم التحديث بنجاح: ${payload.source} | ${formatDateTime(payload.updated_at)}`, 'text-xs text-emerald-300 mt-2');
                await loadNews(false);
            } catch (error) {
                setText('admin-refresh-status', `فشل تحديث المصادر: ${error.message}`, 'text-xs text-red-300 mt-2');
            }
        }

        async function adminLogin() {
            const passwordEl = document.getElementById('admin-password');
            const password = String(passwordEl?.value || '').trim();
            if (!password) {
                setText('admin-login-status', 'يرجى إدخال كلمة المرور.', 'text-xs text-red-300 mt-3');
                return;
            }

            setText('admin-login-status', 'جارٍ التحقق...', 'text-xs text-slate-300 mt-3');
            try {
                const payload = await apiJson('/api/admin/login', {
                    method: 'POST',
                    body: JSON.stringify({ password })
                });
                APP_STATE.adminToken = payload.token;
                setAdminAuthState(true);
                setText('admin-add-status', 'يمكنك الآن إضافة الأخبار.', 'text-xs text-emerald-300 mt-3');
                await refreshAdminManualList();
                await refreshAdminAiHubList();
                await refreshAdminAIStatus();
            } catch (error) {
                const apiHint = APP_STATE.apiBase ? ` | API: ${APP_STATE.apiBase}` : '';
                setText('admin-login-status', `فشل تسجيل الدخول: ${error.message}${apiHint}`, 'text-xs text-red-300 mt-3');
            }
        }

        async function adminLogout() {
            try {
                await apiJson('/api/admin/logout', { method: 'POST' }, true);
            } catch (_) {}
            APP_STATE.adminToken = '';
            setAdminAuthState(false);
            setText('admin-login-status', 'تم تسجيل الخروج.', 'text-xs text-slate-300 mt-3');
        }

        async function adminFetchByLink() {
            const sourceUrl = String(document.getElementById('admin-source-url')?.value || '').trim();
            const category = document.getElementById('admin-category')?.value || 'local';
            if (!sourceUrl) {
                setText('admin-add-status', 'أضف رابط المصدر أولاً.', 'text-xs text-red-300 mt-3');
                return;
            }

            setText('admin-add-status', 'جارٍ استجلاب بيانات الخبر من الرابط...', 'text-xs text-cyan-300 mt-3');
            try {
                const payload = await apiJson('/api/admin/news/extract', {
                    method: 'POST',
                    body: JSON.stringify({ source_url: sourceUrl, category })
                }, true);
                const ex = payload.extracted || {};
                if (ex.title) document.getElementById('admin-title').value = ex.title;
                if (ex.summary) document.getElementById('admin-summary').value = ex.summary;
                if (ex.source) document.getElementById('admin-source').value = ex.source;
                if (ex.image_url) document.getElementById('admin-image-url').value = ex.image_url;
                if (ex.scope && document.getElementById('admin-scope')) {
                    document.getElementById('admin-scope').value = ex.scope;
                }
                setText('admin-add-status', 'تم استجلاب البيانات بنجاح. راجعها ثم اضغط إضافة الخبر.', 'text-xs text-emerald-300 mt-3');
            } catch (error) {
                setText('admin-add-status', `تعذر الاستجلاب من الرابط: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        async function addManualNews() {
            const category = document.getElementById('admin-category')?.value || '';
            const scope = document.getElementById('admin-scope')?.value || 'local';
            const aihubSection = document.getElementById('admin-aihub-section')?.value || 'announcements';
            const title = String(document.getElementById('admin-title')?.value || '').trim();
            const summary = String(document.getElementById('admin-summary')?.value || '').trim();
            const source = String(document.getElementById('admin-source')?.value || '').trim();
            const sourceUrl = String(document.getElementById('admin-source-url')?.value || '').trim();
            let imageUrl = String(document.getElementById('admin-image-url')?.value || '').trim();
            const videoUrl = String(document.getElementById('admin-video-url')?.value || '').trim();
            const imageFile = document.getElementById('admin-image-file')?.files?.[0];

            if (!imageUrl && imageFile) {
                imageUrl = await fileToDataUrl(imageFile);
            }

            setText('admin-add-status', 'جارٍ إضافة الخبر...', 'text-xs text-slate-300 mt-3');
            try {
                await apiJson('/api/admin/news', {
                    method: 'POST',
                    body: JSON.stringify({
                        category,
                        scope,
                        auto_extract: (!title || !summary || !source),
                        aihub_section: category === 'aihub' ? aihubSection : '',
                        title,
                        summary,
                        source,
                        source_url: sourceUrl,
                        image_url: imageUrl,
                        video_url: videoUrl,
                        published_at: new Date().toISOString()
                    })
                }, true);

                ['admin-title', 'admin-summary', 'admin-source', 'admin-source-url', 'admin-image-url', 'admin-video-url'].forEach((id) => {
                    const el = document.getElementById(id);
                    if (el) el.value = '';
                });
                const fileEl = document.getElementById('admin-image-file');
                if (fileEl) fileEl.value = '';

                setText('admin-add-status', 'تمت إضافة الخبر بنجاح.', 'text-xs text-emerald-300 mt-3');
                await Promise.all([loadNews(false), refreshAdminManualList()]);
            } catch (error) {
                setText('admin-add-status', `فشل إضافة الخبر: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        function initAdminPanel() {
            const openBtn = document.getElementById('open-admin-panel');
            const closeBtn = document.getElementById('close-admin-panel');
            const loginBtn = document.getElementById('admin-login-btn');
            const logoutBtn = document.getElementById('admin-logout-btn');
            const addNewsBtn = document.getElementById('admin-add-news-btn');
            const fetchLinkBtn = document.getElementById('admin-fetch-link-btn');
            const refreshListBtn = document.getElementById('admin-refresh-list-btn');
            const categoryEl = document.getElementById('admin-category');
            const modal = document.getElementById('admin-modal');
            const refreshAIBtn = document.getElementById('admin-ai-refresh-btn');
            const statusAIBtn = document.getElementById('admin-ai-status-btn');
            const refreshSourcesBtn = document.getElementById('admin-refresh-sources-btn');
            const manualList = document.getElementById('admin-manual-news-list');
            const homeList = document.getElementById('admin-home-list');
            const apiBaseInput = document.getElementById('api-base-input');
            const apiBaseSaveBtn = document.getElementById('api-base-save-btn');
            const viewCardsBtn = document.getElementById('view-cards-btn');
            const viewTimelineBtn = document.getElementById('view-timeline-btn');
            const refreshNewsBtn = document.getElementById('refresh-news-btn');
            const adminTabNewsBtn = document.getElementById('admin-tab-news-btn');
            const adminTabHomeBtn = document.getElementById('admin-tab-home-btn');
            const adminHomeAddBtn = document.getElementById('admin-home-add-btn');
            const adminHomeRefreshBtn = document.getElementById('admin-home-refresh-btn');

            if (openBtn) {
                openBtn.addEventListener('click', async () => {
                    openAdminModal();
                    setAdminAuthState(Boolean(APP_STATE.adminToken));
                    switchAdminEditorTab('news');
                    toggleAIHubSectionInput();
                    if (apiBaseInput) apiBaseInput.value = APP_STATE.apiBase || '';
                    if (APP_STATE.adminToken) {
                        await refreshAdminManualList();
                        await refreshAdminAiHubList();
                        await refreshAdminAIStatus();
                    }
                });
            }
            if (closeBtn) closeBtn.addEventListener('click', closeAdminModal);
            if (modal) {
                modal.addEventListener('click', (event) => {
                    if (event.target === modal) closeAdminModal();
                });
            }
            if (loginBtn) loginBtn.addEventListener('click', adminLogin);
            if (logoutBtn) logoutBtn.addEventListener('click', adminLogout);
            if (addNewsBtn) addNewsBtn.addEventListener('click', addManualNews);
            if (fetchLinkBtn) fetchLinkBtn.addEventListener('click', adminFetchByLink);
            if (refreshListBtn) refreshListBtn.addEventListener('click', refreshAdminManualList);
            if (categoryEl) categoryEl.addEventListener('change', toggleAIHubSectionInput);
            if (refreshAIBtn) refreshAIBtn.addEventListener('click', adminForceAIRefresh);
            if (statusAIBtn) statusAIBtn.addEventListener('click', refreshAdminAIStatus);
            if (refreshSourcesBtn) refreshSourcesBtn.addEventListener('click', adminRefreshSources);
            if (apiBaseSaveBtn) apiBaseSaveBtn.addEventListener('click', saveApiBaseFromInput);
            if (apiBaseInput) {
                apiBaseInput.value = APP_STATE.apiBase || '';
                apiBaseInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        saveApiBaseFromInput();
                    }
                });
            }
            if (viewCardsBtn) viewCardsBtn.addEventListener('click', () => setViewMode('cards'));
            if (viewTimelineBtn) viewTimelineBtn.addEventListener('click', () => setViewMode('timeline'));
            if (refreshNewsBtn) refreshNewsBtn.addEventListener('click', manualRefreshNews);
            if (adminTabNewsBtn) adminTabNewsBtn.addEventListener('click', () => switchAdminEditorTab('news'));
            if (adminTabHomeBtn) adminTabHomeBtn.addEventListener('click', () => switchAdminEditorTab('home'));
            if (adminHomeAddBtn) adminHomeAddBtn.addEventListener('click', addAiHubHomeItem);
            if (adminHomeRefreshBtn) adminHomeRefreshBtn.addEventListener('click', refreshAdminAiHubList);

            if (manualList) {
                manualList.addEventListener('click', (event) => {
                    const btn = event.target.closest('.admin-delete-news-btn');
                    if (!btn) return;
                    const id = btn.getAttribute('data-news-id');
                    deleteManualNews(id);
                });
            }
            if (homeList) {
                homeList.addEventListener('click', (event) => {
                    const btn = event.target.closest('.admin-delete-news-btn');
                    if (!btn) return;
                    const id = btn.getAttribute('data-news-id');
                    deleteManualNews(id);
                });
            }

            document.addEventListener('click', (event) => {
                const btn = event.target.closest('.news-page-btn');
                if (!btn) return;
                const containerId = btn.getAttribute('data-page-container');
                const action = btn.getAttribute('data-page-action');
                changeNewsPage(containerId, action);
            });

            applyViewModeButtons();
            discoverApiBase();
        }

        setInterval(updateClock, 1000);
        updateClock();
        initAdminPanel();
        initInstallExperience();
        registerServiceWorker();
        switchMainTab('aihub');
        switchAIHubSubTab('aihub-announcements');
        switchArabicSubTab('arabic-local');
        switchGlobalSubTab('global-war');
        switchTechAiSubTab('techai-ai');
        loadNews(false);
        setInterval(() => loadNews(false), PUBLIC_POLL_MS);

