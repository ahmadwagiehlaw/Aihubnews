        function renderNewsList(containerId, items, tone, emptyText = 'لا توجد بيانات حالياً.') {
            const container = document.getElementById(containerId);
            if (!container) return;
            const allItems = Array.isArray(items) ? items : [];
            APP_STATE.listCache[containerId] = { items: allItems, tone, emptyText };
            if (!container.dataset.defaultClass) {
                container.dataset.defaultClass = container.className;
            }
            const isTimeline = APP_STATE.viewMode === 'timeline';
            container.className = isTimeline ? 'space-y-2' : container.dataset.defaultClass;

            if (!allItems.length) {
                container.innerHTML = `<div class="text-xs text-slate-400 bg-slate-900/60 border border-slate-700 rounded-lg p-3">${escapeHtml(emptyText)}</div>`;
                return;
            }

            const pageSize = 10;
            const totalPages = Math.max(1, Math.ceil(allItems.length / pageSize));
            const safePage = Math.min(Math.max(Number(APP_STATE.pagination[containerId] || 1), 1), totalPages);
            APP_STATE.pagination[containerId] = safePage;

            const start = (safePage - 1) * pageSize;
            const visibleItems = allItems.slice(start, start + pageSize);
            let html = visibleItems
                .map((item) => (isTimeline ? buildTimelineItem(item, tone) : buildNewsCard(item, tone)))
                .join('');

            if (allItems.length > pageSize) {
                if (isTimeline) {
                    html += `
                        <div class="bg-slate-900/60 border border-slate-700 rounded-lg p-3 flex items-center justify-between gap-2">
                            <button data-page-container="${escapeAttr(containerId)}" data-page-action="prev" class="news-page-btn text-xs bg-slate-700 hover:bg-slate-600 text-slate-100 px-3 py-1 rounded ${safePage <= 1 ? 'opacity-40 cursor-not-allowed' : ''}" ${safePage <= 1 ? 'disabled' : ''}>السابق</button>
                            <span class="text-xs text-slate-300">صفحة ${safePage} من ${totalPages} | إجمالي الأخبار ${allItems.length}</span>
                            <button data-page-container="${escapeAttr(containerId)}" data-page-action="next" class="news-page-btn text-xs bg-slate-700 hover:bg-slate-600 text-slate-100 px-3 py-1 rounded ${safePage >= totalPages ? 'opacity-40 cursor-not-allowed' : ''}" ${safePage >= totalPages ? 'disabled' : ''}>التالي</button>
                        </div>
                    `;
                } else {
                    html += `
                        <div class="md:col-span-2 xl:col-span-3 bg-slate-900/60 border border-slate-700 rounded-lg p-3 flex items-center justify-between gap-2">
                            <button data-page-container="${escapeAttr(containerId)}" data-page-action="prev" class="news-page-btn text-xs bg-slate-700 hover:bg-slate-600 text-slate-100 px-3 py-1 rounded ${safePage <= 1 ? 'opacity-40 cursor-not-allowed' : ''}" ${safePage <= 1 ? 'disabled' : ''}>السابق</button>
                            <span class="text-xs text-slate-300">صفحة ${safePage} من ${totalPages} | إجمالي الأخبار ${allItems.length}</span>
                            <button data-page-container="${escapeAttr(containerId)}" data-page-action="next" class="news-page-btn text-xs bg-slate-700 hover:bg-slate-600 text-slate-100 px-3 py-1 rounded ${safePage >= totalPages ? 'opacity-40 cursor-not-allowed' : ''}" ${safePage >= totalPages ? 'disabled' : ''}>التالي</button>
                        </div>
                    `;
                }
            }
            container.innerHTML = html;
        }

        function changeNewsPage(containerId, action) {
            const cache = APP_STATE.listCache[containerId];
            if (!cache) return;
            const totalPages = Math.max(1, Math.ceil(cache.items.length / 10));
            let current = Number(APP_STATE.pagination[containerId] || 1);
            if (action === 'next') current += 1;
            if (action === 'prev') current -= 1;
            current = Math.min(Math.max(current, 1), totalPages);
            APP_STATE.pagination[containerId] = current;
            renderNewsList(containerId, cache.items, cache.tone, cache.emptyText);
        }

        function splitAiHub(items) {
            const out = { announcements: [], tools: [], community: [], tutorials: [] };
            (Array.isArray(items) ? items : []).forEach((item) => {
                const section = item?.aihub_section;
                if (section === 'tools') out.tools.push(item);
                else if (section === 'community') out.community.push(item);
                else if (section === 'tutorials') out.tutorials.push(item);
                else out.announcements.push(item);
            });
            return out;
        }

        function ensureScopedPair(scopedMap, category, fallbackItems) {
            const fromApi = scopedMap?.[category] || {};
            const fallback = Array.isArray(fallbackItems) ? fallbackItems : [];
            const apiGlobal = Array.isArray(fromApi.global) ? fromApi.global : [];
            const apiLocal = Array.isArray(fromApi.local) ? fromApi.local : [];

            if (apiGlobal.length || apiLocal.length) {
                return {
                    global: apiGlobal,
                    local: apiLocal
                };
            }

            const global = [];
            const local = [];
            fallback.forEach((item) => {
                if (String(item?.scope || '').toLowerCase() === 'local') local.push(item);
                else global.push(item);
            });
            return { global, local };
        }

        function renderTicker(news) {
            const track = document.getElementById('news-ticker-track');
            if (!track) return;

            const orderedCategories = ['aihub', 'war', 'local', 'economy', 'legal', 'ai', 'tech'];
            const headlines = [];
            orderedCategories.forEach((category) => {
                const label = CATEGORY_META[category]?.label || category;
                (Array.isArray(news?.[category]) ? news[category] : []).slice(0, 4).forEach((item) => {
                    headlines.push({ label, title: item.title || '' });
                });
            });

            if (!headlines.length) {
