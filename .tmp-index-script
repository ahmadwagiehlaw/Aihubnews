                setText('admin-add-status', `تعذر حذف الخبر: ${error.message}`, 'text-xs text-red-300 mt-3');
                setText('admin-home-status', `تعذر حذف العنصر: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        async function refreshAdminManualList() {
            try {
                const payload = await apiJson('/api/admin/news', { method: 'GET' }, true);
                renderAdminManualList(payload.items || []);
                renderAdminAiHubList(payload.items || []);
