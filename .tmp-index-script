        async function apiJson(url, options = {}, needsAuth = false) {
            const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
            if (needsAuth && APP_STATE.adminToken) {
                headers.Authorization = `Bearer ${APP_STATE.adminToken}`;
            }
            const response = await fetchApi(url, { ...options, headers });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || !payload?.ok) throw new Error(payload?.error || `HTTP ${response.status}`);
            return payload;
        }

        function toggleAIHubSectionInput() {
            const categoryEl = document.getElementById('admin-category');
            const sectionEl = document.getElementById('admin-aihub-section');
            const scopeEl = document.getElementById('admin-scope');
            if (!categoryEl || !sectionEl || !scopeEl) return;
            if (categoryEl.value === 'aihub') {
                sectionEl.classList.remove('hidden');
                scopeEl.classList.add('hidden');
            } else {
                sectionEl.classList.add('hidden');
                scopeEl.classList.remove('hidden');
                if (categoryEl.value === 'local') scopeEl.value = 'local';
            }
