        function stripHtmlLite(value) {
            return String(value || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
        }

        function excerptLite(value, maxLen = 220) {
            const clean = stripHtmlLite(value);
            if (clean.length <= maxLen) return clean;
            return `${clean.slice(0, maxLen - 1).trim()}…`;
        }

        function looksArabic(value) {
            return /[\u0600-\u06FF]/.test(String(value || ''));
        }

        function sourceDomainLite(urlValue) {
            try {
                return new URL(urlValue).hostname.replace(/^www\./, '');
            } catch (_) {
                return '';
            }
        }

        function parseRssItemsLite(xmlText) {
            const xml = String(xmlText || '');
            const blocks = [...xml.matchAll(/<item\b[\s\S]*?<\/item>/gi)].map((m) => m[0]);
            const extract = (block, tag) => {
                const match = block.match(new RegExp(`<${tag}[^>]*>([\\s\\S]*?)<\\/${tag}>`, 'i'));
                return match ? match[1] : '';
            };
            const extractLink = (block) => {
                const hrefMatch = block.match(/<link[^>]*href=["']([^"']+)["'][^>]*>/i);
                if (hrefMatch) return hrefMatch[1];
                const textMatch = block.match(/<link[^>]*>([\s\S]*?)<\/link>/i);
                return textMatch ? textMatch[1] : '';
            };
            return blocks.map((block) => ({
                title: stripHtmlLite(extract(block, 'title')),
                description: stripHtmlLite(extract(block, 'description') || extract(block, 'summary')),
                link: stripHtmlLite(extractLink(block)),
                pubDate: stripHtmlLite(extract(block, 'pubDate') || extract(block, 'updated') || extract(block, 'published'))
            }));
        }

        async function fetchRssWithCorsFallback(feedUrl) {
            const urls = [feedUrl, `https://api.allorigins.win/raw?url=${encodeURIComponent(feedUrl)}`];
            for (const candidate of urls) {
                try {
                    const response = await fetchWithTimeout(candidate, { method: 'GET' }, 4500);
                    if (!response.ok) continue;
                    const text = await response.text();
                    if (/<item\b|<entry\b/i.test(text)) return text;
                } catch (_) {}
            }
            return '';
        }

        async function fetchRssViaJson(feedUrl) {
            const endpoint = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(feedUrl)}`;
            try {
                const response = await fetchWithTimeout(endpoint, { method: 'GET' }, 4500);
                if (!response.ok) return [];
                const payload = await response.json();
                if (payload?.status !== 'ok' || !Array.isArray(payload?.items)) return [];
                return payload.items.map((item) => ({
                    title: String(item?.title || '').trim(),
                    description: stripHtmlLite(item?.description || item?.content || item?.title || ''),
                    link: String(item?.link || item?.guid || '').trim(),
                    pubDate: String(item?.pubDate || item?.published || '').trim()
                }));
            } catch (_) {
                return [];
            }
        }

        async function fetchEmergencyFeedItems(feedUrl) {
            const jsonItems = await fetchRssViaJson(feedUrl);
            if (jsonItems.length) return jsonItems;
            const xml = await fetchRssWithCorsFallback(feedUrl);
            return parseRssItemsLite(xml);
        }

        function mapEmergencyItems(items, category, scope) {
            return (Array.isArray(items) ? items : [])
                .map((row, idx) => {
                    const sourceUrl = String(row.link || row.source_url || 'https://news.google.com/').trim();
                    const title = String(row.title || '').trim();
                    const summary = excerptLite(row.description || row.summary || row.title || '', 240);
                    if (!title || !sourceUrl || summary.length < 12) return null;
                    return {
                        id: `em_${category}_${scope}_${Date.now()}_${idx}`,
                        category,
                        scope,
                        title,
                        summary,
                        source: String(row.source || sourceDomainLite(sourceUrl) || 'news'),
                        source_url: sourceUrl,
                        image_url: '',
                        published_at: row.pubDate || '',
                        origin: 'rss',
                        verified: true
                    };
                })
                .filter(Boolean);
        }

        async function buildEmergencyFallbackPayload() {
            const feeds = {
                ar_local: 'https://news.google.com/rss/search?q=أخبار مصر&hl=ar&gl=EG&ceid=EG:ar',
                ar_war: 'https://news.google.com/rss/search?q=الأخبار الجيوسياسية&hl=ar&gl=EG&ceid=EG:ar',
                ar_economy: 'https://news.google.com/rss/search?q=اقتصاد مصر أسعار الفائدة&hl=ar&gl=EG&ceid=EG:ar',
                en_local: 'https://news.google.com/rss/search?q=middle east regional news&hl=en&gl=US&ceid=US:en',
                en_war: 'https://news.google.com/rss/search?q=geopolitics+international+conflict&hl=en&gl=US&ceid=US:en',
                en_economy: 'https://news.google.com/rss/search?q=global+macro+economy+interest+rates+inflation&hl=en&gl=US&ceid=US:en',
                en_ai: 'https://news.google.com/rss/search?q=artificial+intelligence+model+release&hl=en&gl=US&ceid=US:en',
                en_tech: 'https://news.google.com/rss/search?q=technology+cybersecurity+global&hl=en&gl=US&ceid=US:en'
            };

            const [arLocalRaw, arWarRaw, arEconomyRaw, enLocalRaw, enWarRaw, enEconomyRaw, enAiRaw, enTechRaw] = await Promise.all([
                fetchEmergencyFeedItems(feeds.ar_local),
                fetchEmergencyFeedItems(feeds.ar_war),
                fetchEmergencyFeedItems(feeds.ar_economy),
                fetchEmergencyFeedItems(feeds.en_local),
                fetchEmergencyFeedItems(feeds.en_war),
                fetchEmergencyFeedItems(feeds.en_economy),
                fetchEmergencyFeedItems(feeds.en_ai),
                fetchEmergencyFeedItems(feeds.en_tech)
            ]);

            const arLocalItems = mapEmergencyItems((Array.isArray(arLocalRaw) ? arLocalRaw : []).filter((x) => looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'local', 'local');
            const arWarItems = mapEmergencyItems((Array.isArray(arWarRaw) ? arWarRaw : []).filter((x) => looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'war', 'local');
            const arEconomyItems = mapEmergencyItems((Array.isArray(arEconomyRaw) ? arEconomyRaw : []).filter((x) => looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'economy', 'local');
            const enLocalItems = mapEmergencyItems((Array.isArray(enLocalRaw) ? enLocalRaw : []).filter((x) => !looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'local', 'global');
            const enWarItems = mapEmergencyItems((Array.isArray(enWarRaw) ? enWarRaw : []).filter((x) => !looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'war', 'global');
            const enEconomyItems = mapEmergencyItems((Array.isArray(enEconomyRaw) ? enEconomyRaw : []).filter((x) => !looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'economy', 'global');
            const enAiItems = mapEmergencyItems((Array.isArray(enAiRaw) ? enAiRaw : []).filter((x) => !looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'ai', 'global');
            const enTechItems = mapEmergencyItems((Array.isArray(enTechRaw) ? enTechRaw : []).filter((x) => !looksArabic(`${x.title} ${x.description}`)).slice(0, 8), 'tech', 'global');

            if (!arLocalItems.length && !arWarItems.length && !arEconomyItems.length && !enLocalItems.length && !enWarItems.length && !enEconomyItems.length && !enAiItems.length && !enTechItems.length) {
                const staticLocal = mapEmergencyItems(STATIC_LOCAL_FALLBACK.local, 'local', 'local');
                const staticWar = mapEmergencyItems(STATIC_LOCAL_FALLBACK.war, 'war', 'local');
                const staticEconomy = mapEmergencyItems(STATIC_LOCAL_FALLBACK.economy, 'economy', 'local');
                const staticGlobalWar = mapEmergencyItems(STATIC_GLOBAL_FALLBACK.war, 'war', 'global');
                const staticGlobalLocal = mapEmergencyItems(STATIC_GLOBAL_FALLBACK.local, 'local', 'global');
                const staticGlobalEconomy = mapEmergencyItems(STATIC_GLOBAL_FALLBACK.economy, 'economy', 'global');
                const staticGlobalAi = mapEmergencyItems(STATIC_GLOBAL_FALLBACK.ai, 'ai', 'global');
                const staticGlobalTech = mapEmergencyItems(STATIC_GLOBAL_FALLBACK.tech, 'tech', 'global');
                if (!staticLocal.length && !staticWar.length && !staticEconomy.length && !staticGlobalWar.length && !staticGlobalLocal.length && !staticGlobalEconomy.length) return null;
                return {
                    news: APP_STATE.latestPayload?.news || { war: [], local: [], economy: [], legal: [], ai: [], tech: [], aihub: [] },
                    news_scopes: {
                        war: { global: staticGlobalWar, local: staticWar },
                        local: { global: staticGlobalLocal, local: staticLocal },
                        economy: { global: staticGlobalEconomy, local: staticEconomy },
                        ai: { global: staticGlobalAi, local: [] },
                        tech: { global: staticGlobalTech, local: [] }
                    },
                    aihub_sections: APP_STATE.latestPayload?.aihub_sections || { announcements: [], tools: [], community: [], tutorials: [] },
                    source: 'client-static-fallback'
                };
            }

            const fallbackNews = APP_STATE.latestPayload?.news || { war: [], local: [], economy: [], legal: [], ai: [], tech: [], aihub: [] };
            const fallbackScopes = APP_STATE.latestPayload?.news_scopes || {};

            return {
                news: fallbackNews,
                news_scopes: {
                    war: {
                        global: enWarItems.length ? enWarItems : (Array.isArray(fallbackScopes?.war?.global) ? fallbackScopes.war.global : mapEmergencyItems(STATIC_GLOBAL_FALLBACK.war, 'war', 'global')),
                        local: arWarItems.length ? arWarItems : (Array.isArray(fallbackScopes?.war?.local) ? fallbackScopes.war.local : [])
                    },
                    local: {
                        global: enLocalItems.length ? enLocalItems : (Array.isArray(fallbackScopes?.local?.global) ? fallbackScopes.local.global : mapEmergencyItems(STATIC_GLOBAL_FALLBACK.local, 'local', 'global')),
                        local: arLocalItems.length ? arLocalItems : (Array.isArray(fallbackScopes?.local?.local) ? fallbackScopes.local.local : [])
                    },
                    economy: {
                        global: enEconomyItems.length ? enEconomyItems : (Array.isArray(fallbackScopes?.economy?.global) ? fallbackScopes.economy.global : mapEmergencyItems(STATIC_GLOBAL_FALLBACK.economy, 'economy', 'global')),
                        local: arEconomyItems.length ? arEconomyItems : (Array.isArray(fallbackScopes?.economy?.local) ? fallbackScopes.economy.local : [])
                    },
                    ai: {
                        global: enAiItems.length ? enAiItems : (Array.isArray(fallbackScopes?.ai?.global) ? fallbackScopes.ai.global : mapEmergencyItems(STATIC_GLOBAL_FALLBACK.ai, 'ai', 'global')),
                        local: Array.isArray(fallbackScopes?.ai?.local) ? fallbackScopes.ai.local : []
                    },
                    tech: {
                        global: enTechItems.length ? enTechItems : (Array.isArray(fallbackScopes?.tech?.global) ? fallbackScopes.tech.global : mapEmergencyItems(STATIC_GLOBAL_FALLBACK.tech, 'tech', 'global')),
                        local: Array.isArray(fallbackScopes?.tech?.local) ? fallbackScopes.tech.local : []
                    }
                },
                aihub_sections: APP_STATE.latestPayload?.aihub_sections || { announcements: [], tools: [], community: [], tutorials: [] },
                source: 'client-emergency-rss'
            };
        }

        function mergeScopedItems(primaryItems, fallbackItems, minCount = 3) {
            const out = [];
            const seen = new Set();
            const pushItem = (item) => {
                if (!item) return;
                const key = `${String(item.source_url || '').trim()}|${String(item.title || '').trim()}`.toLowerCase();
                if (!key || seen.has(key)) return;
                seen.add(key);
                out.push(item);
            };
            (Array.isArray(primaryItems) ? primaryItems : []).forEach(pushItem);
            if (out.length < minCount) {
                (Array.isArray(fallbackItems) ? fallbackItems : []).forEach(pushItem);
            }
            return out;
        }

        function ensureArabicScopeCoverage(payload, emergencyPayload) {
            if (!payload || !emergencyPayload) return payload;
            const p = payload.news_scopes || {};
            const e = emergencyPayload.news_scopes || {};
            const merged = {
                ...payload,
                news_scopes: {
                    ...p,
                    war: {
                        global: Array.isArray(p?.war?.global) ? p.war.global : [],
                        local: mergeScopedItems(p?.war?.local, e?.war?.local, 3)
                    },
                    local: {
                        global: mergeScopedItems(p?.local?.global, e?.local?.global, 3),
                        local: mergeScopedItems(p?.local?.local, e?.local?.local, 3)
                    },
                    economy: {
                        global: Array.isArray(p?.economy?.global) ? p.economy.global : [],
                        local: mergeScopedItems(p?.economy?.local, e?.economy?.local, 3)
                    },
                    ai: p?.ai || { global: [], local: [] },
                    tech: p?.tech || { global: [], local: [] }
                }
            };
            return merged;
        }

        function getStaticArabicFallback(category) {
            const rows = STATIC_LOCAL_FALLBACK[category] || [];
            const mapped = mapEmergencyItems(rows, category, 'local');
            return mapped.slice(0, 6);
        }

        function getStaticGlobalFallback(category) {
            const rows = STATIC_GLOBAL_FALLBACK[category] || [];
            const mapped = mapEmergencyItems(rows, category, 'global');
            return mapped.slice(0, 8);
        }

        function buildImmediateFallbackPayload() {
            const baseNews = APP_STATE.latestPayload?.news || { war: [], local: [], economy: [], legal: [], ai: [], tech: [], aihub: [] };
            const baseScopes = APP_STATE.latestPayload?.news_scopes || {};
            return {
                ok: true,
                news: baseNews,
                news_scopes: {
                    war: {
                        global: Array.isArray(baseScopes?.war?.global) && baseScopes.war.global.length ? baseScopes.war.global : getStaticGlobalFallback('war'),
                        local: getStaticArabicFallback('war')
                    },
                    local: {
                        global: Array.isArray(baseScopes?.local?.global) && baseScopes.local.global.length ? baseScopes.local.global : getStaticGlobalFallback('local'),
                        local: getStaticArabicFallback('local')
                    },
                    economy: {
                        global: Array.isArray(baseScopes?.economy?.global) && baseScopes.economy.global.length ? baseScopes.economy.global : getStaticGlobalFallback('economy'),
                        local: getStaticArabicFallback('economy')
                    },
                    ai: {
                        global: Array.isArray(baseScopes?.ai?.global) && baseScopes.ai.global.length ? baseScopes.ai.global : getStaticGlobalFallback('ai'),
                        local: Array.isArray(baseScopes?.ai?.local) ? baseScopes.ai.local : []
                    },
                    tech: {
                        global: Array.isArray(baseScopes?.tech?.global) && baseScopes.tech.global.length ? baseScopes.tech.global : getStaticGlobalFallback('tech'),
                        local: Array.isArray(baseScopes?.tech?.local) ? baseScopes.tech.local : []
                    }
                },
                aihub_sections: APP_STATE.latestPayload?.aihub_sections || { announcements: [], tools: [], community: [], tutorials: [] },
                source: 'client-static-fallback'
            };
        }

        function renderMergedTabs(news, payload) {
            const scoped = payload?.news_scopes || {};
            const warScoped = ensureScopedPair(scoped, 'war', news?.war || []);
            const localScoped = ensureScopedPair(scoped, 'local', news?.local || []);
            const economyScoped = ensureScopedPair(scoped, 'economy', news?.economy || []);
            const aiScoped = ensureScopedPair(scoped, 'ai', news?.ai || []);
            const techScoped = ensureScopedPair(scoped, 'tech', news?.tech || []);

            const arabicLocalSafe = Array.isArray(localScoped.local) && localScoped.local.length
                ? localScoped.local
                : getStaticArabicFallback('local');
            const arabicWarSafe = Array.isArray(warScoped.local) && warScoped.local.length
                ? warScoped.local
                : getStaticArabicFallback('war');
            const arabicEconomySafe = Array.isArray(economyScoped.local) && economyScoped.local.length
                ? economyScoped.local
                : getStaticArabicFallback('economy');

            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.arabic_local, arabicLocalSafe, 'sky', 'لا توجد أخبار عربية محلية حالياً.');
            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.arabic_war, arabicWarSafe, 'sky', 'لا توجد أخبار جيوسياسية عربية حالياً.');
            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.arabic_economy, arabicEconomySafe, 'sky', 'لا توجد أخبار اقتصادية عربية حالياً.');

            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.global_war, warScoped.global, 'red', 'لا توجد أخبار جيوسياسية عالمية حالياً.');
            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.global_economy, economyScoped.global, 'emerald', 'لا توجد أخبار اقتصادية عالمية حالياً.');
            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.global_local, localScoped.global, 'amber', 'لا توجد أخبار محلية/إقليمية عالمية حالياً.');

            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.legal_manual, news?.legal || [], 'amber', 'لا توجد أخبار قانونية مضافة يدويًا بعد.');

            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.techai_ai, aiScoped.global, 'violet', 'لا توجد أخبار AI عالمية حالياً.');
            renderNewsList(DYNAMIC_CONTAINER_BY_CATEGORY.techai_tech, techScoped.global, 'cyan', 'لا توجد أخبار تقنية عالمية حالياً.');

            const sections = payload?.aihub_sections || splitAiHub(news?.aihub || []);
            renderNewsList('dynamic-aihub-announcements-list', sections.announcements || [], 'sky', 'لا توجد إعلانات حالياً.');
            renderNewsList('dynamic-aihub-tools-list', sections.tools || [], 'sky', 'لا توجد أدوات مضافة حالياً.');
            renderNewsList('dynamic-aihub-community-list', sections.community || [], 'sky', 'لا توجد فعاليات حالياً.');
            renderNewsList('dynamic-aihub-tutorials-list', sections.tutorials || [], 'sky', 'لا توجد شروحات مضافة حالياً.');
        }

        function renderMarketSnapshot(payload) {
            const grid = document.getElementById('macro-indicators-grid');
            const meta = document.getElementById('macro-indicators-meta');
            if (!grid || !meta) return;

            const indicators = Array.isArray(payload?.indicators) ? payload.indicators : [];
            if (!indicators.length) {
                grid.innerHTML = '<div class="col-span-full text-xs text-slate-400 bg-slate-900/60 border border-slate-700 rounded-lg p-3">لا توجد قراءات لحظية متاحة حالياً.</div>';
                meta.textContent = payload?.error ? `تعذر تحميل المؤشرات: ${payload.error}` : 'تعذر تحميل المؤشرات حالياً.';
                return;
            }

            grid.innerHTML = indicators.map((item) => {
                const isUp = Number(item.change_percent || 0) >= 0;
                const price = item.price === null || item.price === undefined ? '--' : Number(item.price).toLocaleString('en-US', { maximumFractionDigits: 3 });
                const chg = item.change_percent === null || item.change_percent === undefined ? '--' : `${isUp ? '+' : ''}${Number(item.change_percent).toFixed(2)}%`;
                return `
                    <div class="bg-slate-800 p-3 rounded-lg border border-slate-700">
                        <p class="text-[11px] text-slate-400 mb-1">${escapeHtml(item.label || '')}</p>
                        <p class="text-lg font-bold ${isUp ? 'text-emerald-400' : 'text-red-400'}">${escapeHtml(price)}</p>
                        <p class="text-[10px] ${isUp ? 'text-emerald-500' : 'text-red-500'}">${escapeHtml(chg)}</p>
                    </div>
                `;
            }).join('');

            meta.textContent = `آخر تحديث للمؤشرات: ${formatDateTime(payload.updated_at)} | المصدر: Yahoo Finance (بيانات لحظية قد تكون متأخرة دقائق)`;
        }

        async function loadMarketSnapshot() {
            try {
                const response = await fetchApi('/api/market-snapshot', { method: 'GET', headers: { 'Accept': 'application/json' } });
                const payload = await response.json();
                renderMarketSnapshot(payload);
            } catch (error) {
                renderMarketSnapshot({ ok: false, error: error.message, indicators: [] });
            }
        }

        async function loadNews(force = false) {
            try {
                if (!APP_STATE.latestPayload) {
                    const firstFallback = buildImmediateFallbackPayload();
                    APP_STATE.latestPayload = firstFallback;
                    renderMergedTabs(firstFallback.news, firstFallback);
                    renderTicker(firstFallback.news);
                }

                if (!APP_STATE.apiReady && APP_STATE.lastApiFailureAt && (Date.now() - APP_STATE.lastApiFailureAt < API_RETRY_COOLDOWN_MS)) {
                    const quickFallback = buildImmediateFallbackPayload();
                    APP_STATE.latestPayload = quickFallback;
                    renderMergedTabs(quickFallback.news, quickFallback);
                    renderTicker(quickFallback.news);
                    if (!force) return;
                }

                const response = await fetchApi(`/api/news${force ? '?force=1' : ''}`, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' }
                });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                let payload = await response.json();
                if (!payload?.ok) throw new Error(payload?.error || 'تعذر جلب الأخبار');

                const hasArabicLocal =
                    Array.isArray(payload?.news_scopes?.local?.local) && payload.news_scopes.local.local.length > 0;
                const hasArabicWar =
                    Array.isArray(payload?.news_scopes?.war?.local) && payload.news_scopes.war.local.length > 0;
                const hasArabicEconomy =
                    Array.isArray(payload?.news_scopes?.economy?.local) && payload.news_scopes.economy.local.length > 0;

                if (!hasArabicLocal || !hasArabicWar || !hasArabicEconomy) {
                    const emergencyPayload = await buildEmergencyFallbackPayload().catch(() => null);
                    if (emergencyPayload) {
                        payload = ensureArabicScopeCoverage(payload, emergencyPayload);
                    }
                }

                APP_STATE.latestPayload = payload;
                renderMergedTabs(payload.news, payload);
                renderTicker(payload.news);
                loadMarketSnapshot();
            } catch (error) {
                const track = document.getElementById('news-ticker-track');
                const emergencyPayload = await buildEmergencyFallbackPayload().catch(() => null);
                if (emergencyPayload) {
                    APP_STATE.latestPayload = emergencyPayload;
                    renderMergedTabs(emergencyPayload.news, emergencyPayload);
                    renderTicker(emergencyPayload.news);
                    if (track) {
                        track.innerHTML = `<span class="ticker-chip"><i class="fas fa-triangle-exclamation text-amber-400"></i> وضع طوارئ: عرض RSS مباشر من المتصفح بسبب تعذر الاتصال بالخادم.</span>`;
                    }
                    return;
                }
                if (track) {
                    track.innerHTML = `<span class="ticker-chip"><i class="fas fa-triangle-exclamation text-red-400"></i> تعذر جلب الأخبار: ${escapeHtml(error.message)} | تحقق من تشغيل server.js</span>`;
                }
            }
        }

