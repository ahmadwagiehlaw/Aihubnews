        async function addManualNews() {
            const category = document.getElementById('admin-category')?.value || '';
            const scope = document.getElementById('admin-scope')?.value || 'local';
            const aihubSection = document.getElementById('admin-aihub-section')?.value || 'announcements';
            const title = String(document.getElementById('admin-title')?.value || '').trim();
            const summary = String(document.getElementById('admin-summary')?.value || '').trim();
            const source = String(document.getElementById('admin-source')?.value || '').trim();
            const sourceUrl = String(document.getElementById('admin-source-url')?.value || '').trim();
            let imageUrl = String(document.getElementById('admin-image-url')?.value || '').trim();
            const imageFile = document.getElementById('admin-image-file')?.files?.[0];

            if (!imageUrl && imageFile) {
                imageUrl = await fileToDataUrl(imageFile);
            }

            setText('admin-add-status', 'جارٍ إضافة الخبر...', 'text-xs text-slate-300 mt-3');
            try {
                await apiJson('/api/admin/news', {
                    method: 'POST',
                    body: JSON.stringify({
                        category,
                        scope,
                        auto_extract: (!title || !summary || !source),
                        aihub_section: category === 'aihub' ? aihubSection : '',
                        title,
                        summary,
                        source,
                        source_url: sourceUrl,
                        image_url: imageUrl,
                        published_at: new Date().toISOString()
                    })
                }, true);

                ['admin-title', 'admin-summary', 'admin-source', 'admin-source-url', 'admin-image-url'].forEach((id) => {
                    const el = document.getElementById(id);
                    if (el) el.value = '';
                });
                const fileEl = document.getElementById('admin-image-file');
                if (fileEl) fileEl.value = '';

                setText('admin-add-status', 'تمت إضافة الخبر بنجاح.', 'text-xs text-emerald-300 mt-3');
                await Promise.all([loadNews(false), refreshAdminManualList()]);
            } catch (error) {
                setText('admin-add-status', `فشل إضافة الخبر: ${error.message}`, 'text-xs text-red-300 mt-3');
            }
        }

        function initAdminPanel() {
            const openBtn = document.getElementById('open-admin-panel');
            const closeBtn = document.getElementById('close-admin-panel');
            const loginBtn = document.getElementById('admin-login-btn');
            const logoutBtn = document.getElementById('admin-logout-btn');
            const addNewsBtn = document.getElementById('admin-add-news-btn');
            const fetchLinkBtn = document.getElementById('admin-fetch-link-btn');
            const refreshListBtn = document.getElementById('admin-refresh-list-btn');
            const categoryEl = document.getElementById('admin-category');
            const modal = document.getElementById('admin-modal');
            const refreshAIBtn = document.getElementById('admin-ai-refresh-btn');
            const statusAIBtn = document.getElementById('admin-ai-status-btn');
            const refreshSourcesBtn = document.getElementById('admin-refresh-sources-btn');
            const manualList = document.getElementById('admin-manual-news-list');
            const apiBaseInput = document.getElementById('api-base-input');
            const apiBaseSaveBtn = document.getElementById('api-base-save-btn');
            const viewCardsBtn = document.getElementById('view-cards-btn');
            const viewTimelineBtn = document.getElementById('view-timeline-btn');

            if (openBtn) {
                openBtn.addEventListener('click', async () => {
                    openAdminModal();
                    setAdminAuthState(Boolean(APP_STATE.adminToken));
                    toggleAIHubSectionInput();
                    if (apiBaseInput) apiBaseInput.value = APP_STATE.apiBase || '';
                    if (APP_STATE.adminToken) {
                        await refreshAdminManualList();
                        await refreshAdminAIStatus();
                    }
                });
            }
            if (closeBtn) closeBtn.addEventListener('click', closeAdminModal);
            if (modal) {
                modal.addEventListener('click', (event) => {
                    if (event.target === modal) closeAdminModal();
                });
            }
            if (loginBtn) loginBtn.addEventListener('click', adminLogin);
            if (logoutBtn) logoutBtn.addEventListener('click', adminLogout);
            if (addNewsBtn) addNewsBtn.addEventListener('click', addManualNews);
            if (fetchLinkBtn) fetchLinkBtn.addEventListener('click', adminFetchByLink);
            if (refreshListBtn) refreshListBtn.addEventListener('click', refreshAdminManualList);
            if (categoryEl) categoryEl.addEventListener('change', toggleAIHubSectionInput);
            if (refreshAIBtn) refreshAIBtn.addEventListener('click', adminForceAIRefresh);
            if (statusAIBtn) statusAIBtn.addEventListener('click', refreshAdminAIStatus);
            if (refreshSourcesBtn) refreshSourcesBtn.addEventListener('click', adminRefreshSources);
            if (apiBaseSaveBtn) apiBaseSaveBtn.addEventListener('click', saveApiBaseFromInput);
            if (apiBaseInput) {
                apiBaseInput.value = APP_STATE.apiBase || '';
                apiBaseInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        saveApiBaseFromInput();
                    }
                });
            }
            if (viewCardsBtn) viewCardsBtn.addEventListener('click', () => setViewMode('cards'));
            if (viewTimelineBtn) viewTimelineBtn.addEventListener('click', () => setViewMode('timeline'));

            if (manualList) {
                manualList.addEventListener('click', (event) => {
                    const btn = event.target.closest('.admin-delete-news-btn');
                    if (!btn) return;
                    const id = btn.getAttribute('data-news-id');
                    deleteManualNews(id);
                });
            }

            document.addEventListener('click', (event) => {
                const btn = event.target.closest('.news-page-btn');
                if (!btn) return;
                const containerId = btn.getAttribute('data-page-container');
                const action = btn.getAttribute('data-page-action');
                changeNewsPage(containerId, action);
            });

            applyViewModeButtons();
            discoverApiBase();
        }

