        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function escapeAttr(value) {
            return escapeHtml(value).replace(/`/g, '&#96;');
        }

        function formatDateTime(value) {
            if (!value) return '--';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            return date.toLocaleString('ar-EG', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function normalizeApiBase(base) {
            const raw = String(base || '').trim();
            if (!raw) return '';
            let out = raw;
            if (!/^https?:\/\//i.test(out)) {
                out = `${window.location.protocol}//${out}`;
            }
            out = out.replace(/\/+$/g, '');
            return out;
        }

        function setApiStatus(text, kind = 'muted') {
            const el = document.getElementById('api-base-status');
            if (!el) return;
            const cls = kind === 'ok'
                ? 'text-xs text-emerald-300 mt-2'
                : kind === 'error'
                    ? 'text-xs text-red-300 mt-2'
                    : 'text-xs text-slate-400 mt-2';
            el.className = cls;
            el.textContent = text;
        }

        function setApiBase(base, persist = true) {
            const normalized = normalizeApiBase(base);
            APP_STATE.apiBase = normalized;
            APP_STATE.apiReady = false;
            if (!persist) return;

            if (!normalized || normalized === window.location.origin) {
                localStorage.removeItem('aihub_api_base');
            } else {
                localStorage.setItem('aihub_api_base', normalized);
            }
        }

        function buildAutoApiCandidates() {
            const protocol = window.location.protocol || 'http:';
            const host = window.location.hostname || '127.0.0.1';
            const activePort = String(window.location.port || '').trim();
            const ports = [...new Set([activePort, ...API_PORT_CANDIDATES].filter(Boolean))];
            const hosts = [...new Set([host, '127.0.0.1', 'localhost'])];

            const out = [''];
            hosts.forEach((h) => {
                ports.forEach((p) => {
                    out.push(`${protocol}//${h}:${p}`);
                });
            });
            return [...new Set(out.map((base) => normalizeApiBase(base) || ''))];
        }

        function buildApiUrl(path, base = '') {
            const safePath = String(path || '').startsWith('/') ? String(path || '') : `/${String(path || '')}`;
            if (!base) return safePath;
            return `${base}${safePath}`;
        }

        function getOrderedApiBases() {
            const known = buildAutoApiCandidates();
            if (APP_STATE.apiBase && !known.includes(APP_STATE.apiBase)) known.unshift(APP_STATE.apiBase);
            if (APP_STATE.apiBase || APP_STATE.apiBase === '') {
                return [APP_STATE.apiBase, ...known.filter((x) => x !== APP_STATE.apiBase)];
            }
            return known;
        }

        async function discoverApiBase() {
            if (APP_STATE.discoveringApi) return APP_STATE.apiReady;
            APP_STATE.discoveringApi = true;
            try {
                const bases = getOrderedApiBases();
                for (const base of bases) {
                    const healthUrl = buildApiUrl('/api/health', base);
                    try {
                        const response = await fetch(healthUrl, { method: 'GET', headers: { Accept: 'application/json' } });
                        if (!response.ok) continue;
                        const payload = await response.json().catch(() => null);
                        if (!payload || payload.ok !== true) continue;
                        setApiBase(base, true);
                        APP_STATE.apiReady = true;
                        setApiStatus(`تم الاتصال بخادم الأخبار: ${base || 'نفس رابط الصفحة'}`, 'ok');
                        const input = document.getElementById('api-base-input');
                        if (input) input.value = APP_STATE.apiBase || '';
                        return true;
                    } catch (_) {
                        // Try next base
                    }
                }
                APP_STATE.apiReady = false;
                setApiStatus('تعذر اكتشاف خادم API. شغّل server.js ثم أدخل الرابط يدويًا.', 'error');
                return false;
            } finally {
                APP_STATE.discoveringApi = false;
            }
        }

        async function fetchApi(path, options = {}) {
            if (!APP_STATE.apiReady) {
                await discoverApiBase();
            }
            const bases = getOrderedApiBases();
            let lastError = null;

            for (const base of bases) {
                const url = buildApiUrl(path, base);
                try {
                    const response = await fetch(url, options);
                    if (response.ok || [400, 401, 403].includes(response.status)) {
                        setApiBase(base, true);
                        APP_STATE.apiReady = true;
                        return response;
                    }
                    if ([404, 405, 502, 503, 504].includes(response.status)) {
                        lastError = new Error(`HTTP ${response.status}`);
                        continue;
                    }
                    setApiBase(base, true);
                    APP_STATE.apiReady = true;
                    return response;
                } catch (error) {
                    lastError = error;
                }
            }
            APP_STATE.apiReady = false;
            setApiStatus('فشل الاتصال بـ API. تأكد أن server.js يعمل ثم أعد المحاولة.', 'error');
            throw (lastError || new Error('تعذر الوصول إلى واجهة الـ API'));
        }

