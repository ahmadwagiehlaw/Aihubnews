        async function adminFetchByLink() {
            const sourceUrl = String(document.getElementById('admin-source-url')?.value || '').trim();
            const category = document.getElementById('admin-category')?.value || 'local';
            if (!sourceUrl) {
                setText('admin-add-status', 'أضف رابط المصدر أولاً.', 'text-xs text-red-300 mt-3');
