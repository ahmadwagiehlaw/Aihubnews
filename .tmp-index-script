            const btn = document.getElementById('refresh-news-btn');
            if (btn) {
                btn.disabled = true;
                btn.classList.add('opacity-60', 'cursor-not-allowed');
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحديث...';
            }
            try {
                const optimistic = buildImmediateFallbackPayload();
                APP_STATE.latestPayload = optimistic;
                renderMergedTabs(optimistic.news, optimistic);
                renderTicker(optimistic.news);
                await loadNews(true);
